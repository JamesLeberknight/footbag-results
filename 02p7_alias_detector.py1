#!/usr/bin/env python3
"""
02p7_alias_detector.py

Detect likely alias -> canonical-name mappings.

Rules:
- alias/source names come from Placements_Flat person names
- canonical targets come ONLY from Persons_Truth.person_canon
- no auto-merging
- outputs review files only

Outputs:
- out/alias_candidates.csv
- out/alias_candidates_strong.csv
"""

from __future__ import annotations

import re
from collections import defaultdict
from pathlib import Path

import pandas as pd

ROOT = Path.home() / "projects" / "FOOTBAG_DATA"
PF_PATH = ROOT / "out" / "Placements_Flat.csv"
PT_PATH = ROOT / "out" / "Persons_Truth.csv"

OUT_ALL = ROOT / "out" / "alias_candidates.csv"
OUT_STRONG = ROOT / "out" / "alias_candidates_strong.csv"

IGNORE_NAMES = {
    "",
    "__NON_PERSON__",
}

STOPWORDS = {
    "aka", "the", "and", "of", "de", "der", "van", "von", "da", "di", "la", "le",
    "el", "og", "aus", "ka", "ma"
}

KNOWN_LOCATION_PREFIXES = {
    "Chicago", "Urbana", "Charleston", "Milan", "Selma",
    "Vancouver", "Malta", "Sherman", "Winfield", "Pittsburgh",
    "Wichita", "Austin", "Hebron", "McPherson",
}


def norm_space(s: str) -> str:
    return re.sub(r"\s+", " ", str(s).strip())


def clean_alias_candidate(name: str) -> str:
    """Conservative cleanup for observed alias/source names only."""
    if not isinstance(name, str):
        return ""

    s = name.strip()

    s = re.sub(r"^\s*nd=\s*", "", s, flags=re.I)
    s = re.sub(r"-prizes\b", "", s, flags=re.I)
    s = s.replace("�", "")
    s = re.sub(r"\s+", " ", s).strip()

    parts = s.split()
    if len(parts) >= 3 and parts[0] in KNOWN_LOCATION_PREFIXES:
        s = " ".join(parts[1:])

    return norm_space(s)


def canon_name(s: str) -> str:
    s = norm_space(s)
    s = s.replace("’", "'").replace("`", "'")
    s = s.replace("-", " ")
    s = re.sub(r"\s+", " ", s).strip()
    return s


def name_tokens(s: str) -> list[str]:
    toks = [t for t in re.split(r"\s+", canon_name(s)) if t]
    return [t for t in toks if t.lower() not in STOPWORDS]


def token_set(s: str) -> set[str]:
    return {t.lower() for t in name_tokens(s)}


def suffix_match(alias: str, canonical: str) -> bool:
    a = [t.lower() for t in name_tokens(alias)]
    b = [t.lower() for t in name_tokens(canonical)]
    if not a or not b or len(a) >= len(b):
        return False
    return b[-len(a):] == a


def prefix_match(alias: str, canonical: str) -> bool:
    a = [t.lower() for t in name_tokens(alias)]
    b = [t.lower() for t in name_tokens(canonical)]
    if not a or not b or len(a) >= len(b):
        return False
    return b[:len(a)] == a


def contained_match(alias: str, canonical: str) -> bool:
    a = token_set(alias)
    b = token_set(canonical)
    if not a or not b:
        return False
    if a == b:
        return False
    return a.issubset(b)


def looks_like_initial_variant(alias: str, canonical: str) -> bool:
    """
    J Walters -> John Walters
    A Noller -> Adam Noller
    """
    a = name_tokens(alias)
    b = name_tokens(canonical)
    if len(a) != len(b):
        return False
    if len(a) < 2:
        return False
    if a[-1].lower() != b[-1].lower():
        return False

    ok = True
    for x, y in zip(a[:-1], b[:-1]):
        if len(x) == 1 and y.lower().startswith(x.lower()):
            continue
        if x.lower() == y.lower():
            continue
        ok = False
    return ok


def alias_is_weaker(alias: str, canonical: str) -> bool:
    """
    Require alias to be clearly weaker/shorter/noisier than target.
    """
    a = name_tokens(alias)
    b = name_tokens(canonical)
    if not a or not b:
        return False
    if len(a) < len(b):
        return True
    if len(" ".join(a)) < len(" ".join(b)):
        return True
    if looks_like_initial_variant(alias, canonical):
        return True
    return False


def shared_event_overlap(alias: str, canonical: str, name_to_events: dict[str, set[str]]) -> int:
    return len(name_to_events.get(alias, set()) & name_to_events.get(canonical, set()))


def score_pair(alias: str, canonical: str, alias_freq: int, canonical_freq: int, overlap: int) -> tuple[int, str]:
    score = 0
    reasons = []

    if suffix_match(alias, canonical):
        score += 5
        reasons.append("suffix_match")

    if prefix_match(alias, canonical):
        score += 3
        reasons.append("prefix_match")

    if contained_match(alias, canonical):
        score += 2
        reasons.append("token_subset")

    if looks_like_initial_variant(alias, canonical):
        score += 4
        reasons.append("initial_variant")

    if overlap > 0:
        score += min(3, overlap)
        reasons.append(f"same_event_overlap={overlap}")

    if alias_freq <= 3 and canonical_freq >= alias_freq:
        score += 1
        reasons.append("rare_alias")

    return score, ",".join(reasons)


def main():
    if not PF_PATH.exists():
        raise FileNotFoundError(PF_PATH)
    if not PT_PATH.exists():
        raise FileNotFoundError(PT_PATH)

    pf = pd.read_csv(PF_PATH)
    pt = pd.read_csv(PT_PATH)

    pf_name_col = None
    for col in ["person_canon", "display_name", "person_name"]:
        if col in pf.columns:
            pf_name_col = col
            break
    if pf_name_col is None:
        raise ValueError("Could not find name column in Placements_Flat.csv")

    if "person_canon" not in pt.columns:
        raise ValueError("Persons_Truth.csv must contain person_canon")

    # Observed source names from placements
    pf_names = (
        pf[pf_name_col]
        .dropna()
        .astype(str)
        .map(clean_alias_candidate)
        .map(norm_space)
    )
    pf_names = pf_names[~pf_names.isin(IGNORE_NAMES)]
    pf_names = pf_names[pf_names != "__NON_PERSON__"]

    alias_freq = pf_names.value_counts().to_dict()

    # Canonical targets only from Persons_Truth
    canonical_names = (
        pt["person_canon"]
        .dropna()
        .astype(str)
        .map(norm_space)
        .unique()
        .tolist()
    )
    canonical_set = set(canonical_names)

    # Alias sources = observed names not already canonical
    alias_sources = sorted(set(pf_names) - canonical_set)

    # Event overlap map from observed names
    if "event_id" not in pf.columns:
        raise ValueError("Placements_Flat.csv missing event_id")

    name_to_events = (
        pf[[pf_name_col, "event_id"]]
        .dropna()
        .assign(_name=lambda d: d[pf_name_col].astype(str).map(clean_alias_candidate).map(norm_space))
        .query("_name != '__NON_PERSON__'")
        .groupby("_name")["event_id"]
        .agg(lambda s: set(map(str, s)))
        .to_dict()
    )

    # Token index for canonical names only
    canon_token_index: dict[str, set[str]] = defaultdict(set)
    for cname in canonical_names:
        for tok in token_set(cname):
            canon_token_index[tok].add(cname)

    rows = []

    for alias in alias_sources:
        if not alias or alias in IGNORE_NAMES:
            continue

        candidate_pool = set()
        for tok in token_set(alias):
            candidate_pool.update(canon_token_index[tok])

        for canonical in sorted(candidate_pool):
            if alias == canonical:
                continue
            if not alias_is_weaker(alias, canonical):
                continue

            overlap = shared_event_overlap(alias, canonical, name_to_events)
            score, reasons = score_pair(
                alias=alias,
                canonical=canonical,
                alias_freq=alias_freq.get(alias, 0),
                canonical_freq=alias_freq.get(canonical, 0),
                overlap=overlap,
            )

            if score < 4:
                continue

            rows.append({
                "alias": alias,
                "canonical": canonical,
                "alias_count": alias_freq.get(alias, 0),
                "canonical_count_in_pf": alias_freq.get(canonical, 0),
                "shared_events": overlap,
                "score": score,
                "reasons": reasons,
            })

    out = pd.DataFrame(rows)
    if out.empty:
        print("No alias candidates found.")
        out.to_csv(OUT_ALL, index=False)
        out.to_csv(OUT_STRONG, index=False)
        return

    out = out.sort_values(
        ["score", "shared_events", "alias_count", "canonical", "alias"],
        ascending=[False, False, True, True, True],
    )

    out.to_csv(OUT_ALL, index=False)

    strong = out[
        (out["score"] >= 6)
        | (
            out["reasons"].str.contains("suffix_match", na=False)
            & out["reasons"].str.contains("same_event_overlap", na=False)
        )
        | out["reasons"].str.contains("initial_variant", na=False)
    ].copy()

    # Keep best canonical per alias first in strong output
    strong = strong.sort_values(
        ["alias", "score", "shared_events"],
        ascending=[True, False, False],
    ).drop_duplicates(subset=["alias"], keep="first")

    strong.to_csv(OUT_STRONG, index=False)

    print(f"Wrote: {OUT_ALL} ({len(out)} rows)")
    print(f"Wrote: {OUT_STRONG} ({len(strong)} rows)")
    print("\nTop strong candidates:")
    print(strong.head(50).to_string(index=False))


if __name__ == "__main__":
    main()
