#!/usr/bin/env python3
from __future__ import annotations

from pathlib import Path
import re
import pandas as pd

CSV_PATH = Path("out/Placements_Flat.csv")
OUT_HITS = Path("out/qc_structural_v2_hits.csv")
OUT_SUMMARY = Path("out/qc_structural_v2_summary.csv")

DAYS_RE = re.compile(r"\b(monday|tuesday|wednesday|thursday|friday|saturday|sunday)\b", re.I)
COUNTRIES_RE = re.compile(
    r"\b(usa|united states|canada|germany|france|finland|japan|australia|poland|czech|"
    r"czech republic|hungary|italy|switzerland|netherlands|slovakia|sweden|denmark|"
    r"norway|uk|united kingdom|england|scotland|wales)\b",
    re.I,
)
ROUND_TERMS_RE = re.compile(
    r"\b(pool|pools|prelim|prelims|preliminary|semi|semis|semi-final|semifinal|"
    r"quarterfinal|quarter-final|final|finals)\b",
    re.I,
)
DIVISION_TERMS_RE = re.compile(
    r"\b(open|intermediate|novice|women|women's|womens|mixed|singles|doubles|routine|"
    r"freestyle|net|golf|shred|sick\s*3|consecutive|consecutives|request|circle)\b",
    re.I,
)
PUNCT_EDGE_RE = re.compile(r"^[^\w]+|[^\w]+$")


def first_existing(df: pd.DataFrame, names: list[str]) -> str | None:
    for n in names:
        if n in df.columns:
            return n
    return None


def sstr(s: pd.Series) -> pd.Series:
    return s.fillna("").astype(str)


def add_hit_frames(hits: list[pd.DataFrame], frame: pd.DataFrame, rule: str, detail: str, cols: list[str]) -> None:
    if frame.empty:
        return
    out = frame.copy()
    out.insert(0, "qc_rule", rule)
    out.insert(1, "qc_detail", detail)
    keep = ["qc_rule", "qc_detail"] + [c for c in cols if c in out.columns]
    hits.append(out[keep].drop_duplicates())


def main() -> None:
    df = pd.read_csv(CSV_PATH, low_memory=False)

    event_id_col = first_existing(df, ["event_id"])
    year_col = first_existing(df, ["year"])
    event_name_col = first_existing(df, ["event_name", "event"])
    division_col = first_existing(df, ["division_canon", "division_raw", "division"])
    person_col = first_existing(df, ["person_canon", "player_name", "person_name", "name", "person"])
    place_col = first_existing(df, ["place"])
    city_col = first_existing(df, ["city"])
    country_col = first_existing(df, ["country"])
    norm_col = first_existing(df, ["norm", "norm_name", "person_norm"])

    required = [event_id_col, division_col, person_col, place_col]
    if any(c is None for c in required):
        raise ValueError(f"Missing required columns. Found: {df.columns.tolist()}")

    key_cols = [
        c for c in [
            event_id_col, year_col, event_name_col, division_col, place_col,
            person_col, city_col, country_col, norm_col
        ] if c is not None
    ]

    df["_place_num"] = pd.to_numeric(df[place_col], errors="coerce")
    df["_person_str"] = sstr(df[person_col]).str.strip()
    df["_division_str"] = sstr(df[division_col]).str.strip()
    df["_event_str"] = sstr(df[event_name_col]).str.strip() if event_name_col else ""
    df["_country_str"] = sstr(df[country_col]).str.strip() if country_col else ""
    df["_city_str"] = sstr(df[city_col]).str.strip() if city_col else ""

    hits: list[pd.DataFrame] = []

    # 1. Weekday contamination in key structured fields
    mask = (
        df["_person_str"].str.contains(DAYS_RE, regex=True) |
        df["_division_str"].str.contains(DAYS_RE, regex=True) |
        (df["_event_str"].str.contains(DAYS_RE, regex=True) if event_name_col else False) |
        (df["_city_str"].str.contains(DAYS_RE, regex=True) if city_col else False)
    )
    add_hit_frames(hits, df.loc[mask], "V2_R01_WEEKDAY_CONTAMINATION", "weekday found in structured field", key_cols)

    # 2. Country leakage into person field
    mask = df["_person_str"].str.contains(COUNTRIES_RE, regex=True)
    add_hit_frames(hits, df.loc[mask], "V2_R02_COUNTRY_IN_PERSON", "country token in person field", key_cols)

    # 3. Punctuation artifact on person field edges
    mask = df["_person_str"].ne("") & df["_person_str"].str.contains(PUNCT_EDGE_RE, regex=True)
    add_hit_frames(hits, df.loc[mask], "V2_R03_PUNCT_EDGE_PERSON", "leading/trailing punctuation in person field", key_cols)

    # 4. Exact duplicate placement row
    dup_mask = df.duplicated([event_id_col, division_col, place_col, person_col], keep=False)
    add_hit_frames(hits, df.loc[dup_mask], "V2_R04_EXACT_DUPLICATE_ROW", "duplicate event+division+place+person row", key_cols)

    # 5. Same person appears more than once in same event+division
    grp = (
        df.groupby([event_id_col, division_col, person_col], dropna=False)
        .size()
        .reset_index(name="n_rows")
    )
    bad = grp[grp["n_rows"] > 1]
    if not bad.empty:
        flagged = df.merge(
            bad[[event_id_col, division_col, person_col]],
            on=[event_id_col, division_col, person_col],
            how="inner"
        )
        add_hit_frames(hits, flagged, "V2_R05_PERSON_REPEATED_IN_DIVISION", "same person appears multiple times in same event+division", key_cols)

    # 6. Same person appears at multiple places in same event+division
    grp = (
        df.groupby([event_id_col, division_col, person_col], dropna=False)["_place_num"]
        .nunique(dropna=True)
        .reset_index(name="n_places")
    )
    bad = grp[grp["n_places"] > 1]
    if not bad.empty:
        flagged = df.merge(
            bad[[event_id_col, division_col, person_col]],
            on=[event_id_col, division_col, person_col],
            how="inner"
        )
        add_hit_frames(hits, flagged, "V2_R06_PERSON_MULTIPLE_PLACES", "same person has multiple places in same event+division", key_cols)

    # 7. Likely pool/finals merged: repeated person + round terms in division/event
    grp = (
        df.groupby([event_id_col, division_col, person_col], dropna=False)["_place_num"]
        .nunique(dropna=True)
        .reset_index(name="n_places")
    )
    bad = grp[grp["n_places"] > 1]
    if not bad.empty:
        flagged = df.merge(
            bad[[event_id_col, division_col, person_col]],
            on=[event_id_col, division_col, person_col],
            how="inner"
        )
        round_mask = (
            flagged["_division_str"].str.contains(ROUND_TERMS_RE, regex=True) |
            (flagged["_event_str"].str.contains(ROUND_TERMS_RE, regex=True) if event_name_col else False)
        )
        add_hit_frames(hits, flagged.loc[round_mask], "V2_R07_LIKELY_POOL_FINALS_MERGE", "repeated person + round terms suggest pool/finals merge", key_cols)

    # 8. Min place > 1 in event+division
    grp = (
        df.groupby([event_id_col, division_col], dropna=False)["_place_num"]
        .min()
        .reset_index(name="min_place")
    )
    bad = grp[grp["min_place"] > 1]
    if not bad.empty:
        flagged = df.merge(
            bad[[event_id_col, division_col]],
            on=[event_id_col, division_col],
            how="inner"
        )
        add_hit_frames(hits, flagged, "V2_R08_MIN_PLACE_GT_1", "division starts above place 1", key_cols)

    # 9. Suspicious many unique places=1 for same event+division
    grp = (
        df[df["_place_num"] == 1]
        .groupby([event_id_col, division_col], dropna=False)
        .size()
        .reset_index(name="n_first_place_rows")
    )
    bad = grp[grp["n_first_place_rows"] > 2]  # >2 avoids normal doubles teams
    if not bad.empty:
        flagged = df.merge(
            bad[[event_id_col, division_col]],
            on=[event_id_col, division_col],
            how="inner"
        )
        add_hit_frames(hits, flagged, "V2_R09_TOO_MANY_FIRST_PLACE_ROWS", "more than 2 first-place rows in event+division", key_cols)

    # 10. Likely merged divisions: repeated place numbers within event+division, not just ties
    grp = (
        df.groupby([event_id_col, division_col, place_col], dropna=False)
        .size()
        .reset_index(name="n_rows")
    )
    bad = grp[grp["n_rows"] > 2]  # >2 avoids simple doubles teams
    if not bad.empty:
        flagged = df.merge(
            bad[[event_id_col, division_col, place_col]],
            on=[event_id_col, division_col, place_col],
            how="inner"
        )
        add_hit_frames(hits, flagged, "V2_R10_REPEATED_PLACE_RUNS", "same place appears >2 times in event+division", key_cols)

    # 11. Division field itself contains round terms
    mask = df["_division_str"].str.contains(ROUND_TERMS_RE, regex=True)
    add_hit_frames(hits, df.loc[mask], "V2_R11_ROUND_TEXT_IN_DIVISION", "division label contains round term", key_cols)

    # 12. Person field contains division terms
    mask = df["_person_str"].str.contains(DIVISION_TERMS_RE, regex=True)
    add_hit_frames(hits, df.loc[mask], "V2_R12_DIVISION_TEXT_IN_PERSON", "division term leaked into person field", key_cols)

    # 13. Empty or placeholder person
    mask = df["_person_str"].str.lower().isin({"", "nan", "none", "_non_person", "unknown", "n/a", "na", "tbd"})
    add_hit_frames(hits, df.loc[mask], "V2_R13_EMPTY_PERSON", "empty or placeholder person field", key_cols)

    # 14. Same event+division has very low place variety but many rows
    grp = (
        df.groupby([event_id_col, division_col], dropna=False)
        .agg(n_rows=(person_col, "size"), n_places=("_place_num", "nunique"))
        .reset_index()
    )
    bad = grp[(grp["n_rows"] >= 6) & (grp["n_places"] <= 2)]
    if not bad.empty:
        flagged = df.merge(
            bad[[event_id_col, division_col]],
            on=[event_id_col, division_col],
            how="inner"
        )
        add_hit_frames(hits, flagged, "V2_R14_LOW_PLACE_VARIETY", "many rows but only 1-2 distinct places", key_cols)

    # 15. Same person duplicated exactly within event+division+place
    grp = (
        df.groupby([event_id_col, division_col, place_col, person_col], dropna=False)
        .size()
        .reset_index(name="n_rows")
    )
    bad = grp[grp["n_rows"] > 1]
    if not bad.empty:
        flagged = df.merge(
            bad[[event_id_col, division_col, place_col, person_col]],
            on=[event_id_col, division_col, place_col, person_col],
            how="inner"
        )
        add_hit_frames(hits, flagged, "V2_R15_PERSON_DUPLICATED_AT_SAME_PLACE", "same person duplicated at same place", key_cols)

    hits_df = pd.concat(hits, ignore_index=True).drop_duplicates() if hits else pd.DataFrame(columns=["qc_rule", "qc_detail"] + key_cols)
    summary_df = (
        hits_df.groupby(["qc_rule", "qc_detail"], dropna=False)
        .size()
        .reset_index(name="row_count")
        .sort_values(["row_count", "qc_rule"], ascending=[False, True])
    )

    OUT_HITS.parent.mkdir(parents=True, exist_ok=True)
    hits_df.to_csv(OUT_HITS, index=False)
    summary_df.to_csv(OUT_SUMMARY, index=False)

    print(f"Rows scanned: {len(df):,}")
    print(f"Hit rows: {len(hits_df):,}")
    print(f"Wrote: {OUT_HITS}")
    print(f"Wrote: {OUT_SUMMARY}")
    if not summary_df.empty:
        print("\nTop triggered rules:")
        print(summary_df.to_string(index=False))


if __name__ == "__main__":
    main()
