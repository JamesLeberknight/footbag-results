#!/usr/bin/env python3
from __future__ import annotations

import csv
import re
import sys
import time
from pathlib import Path
from urllib.parse import quote_plus

import requests
from bs4 import BeautifulSoup

PT_PATH = Path("out/Persons_Truth.csv")
CACHE_PATH = Path("out/member_lookup_cache.csv")
AMBIG_PATH = Path("out/member_lookup_ambiguous.csv")
MISS_PATH = Path("out/member_lookup_no_match.csv")

BASE = "https://www.footbag.org"
SEARCH_URL = BASE + "/members/search/"
PROFILE_RE = re.compile(r"/members/(?:profile|profile2?)/(\d+)", re.I)

# conservative throttling
SLEEP_SECONDS = 1.0
TIMEOUT = 20

HEADERS = {
    "User-Agent": "Mozilla/5.0 (compatible; footbag-member-id-miner/1.0)"
}


def norm_name(s: str) -> str:
    s = (s or "").strip().lower()
    s = re.sub(r"\s+", " ", s)
    s = re.sub(r"[^\w\s'-]", "", s)
    return s


def load_cache(path: Path) -> dict[str, dict]:
    if not path.exists():
        return {}
    out: dict[str, dict] = {}
    with path.open("r", encoding="utf-8", newline="") as f:
        for row in csv.DictReader(f):
            out[row["person_canon"]] = row
    return out


def save_rows(path: Path, rows: list[dict], fieldnames: list[str]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("w", encoding="utf-8", newline="") as f:
        w = csv.DictWriter(f, fieldnames=fieldnames)
        w.writeheader()
        w.writerows(rows)


def extract_candidates_from_html(html: str) -> list[dict]:
    soup = BeautifulSoup(html, "html.parser")
    candidates: list[dict] = []

    # find all links to member profiles
    seen = set()
    for a in soup.find_all("a", href=True):
        href = a["href"]
        m = PROFILE_RE.search(href)
        if not m:
            continue
        member_id = m.group(1)
        full_url = href if href.startswith("http") else BASE + href
        if member_id in seen:
            continue
        seen.add(member_id)

        text = a.get_text(" ", strip=True)
        candidates.append(
            {
                "member_id": member_id,
                "profile_url": full_url,
                "link_text": text,
            }
        )
    return candidates


def fetch_profile_name(session: requests.Session, url: str) -> str:
    r = session.get(url, headers=HEADERS, timeout=TIMEOUT)
    r.raise_for_status()
    soup = BeautifulSoup(r.text, "html.parser")

    # try title first
    title = soup.title.get_text(" ", strip=True) if soup.title else ""
    m = re.search(r"Member Profile for\s+(.+)", title, re.I)
    if m:
        return m.group(1).strip()

    # fallback: h1/h2
    for tag in ("h1", "h2", "b", "strong"):
        el = soup.find(tag)
        if el:
            txt = el.get_text(" ", strip=True)
            if txt:
                return txt
    return ""


def search_member(session: requests.Session, person_name: str) -> tuple[str, list[dict]]:
    """
    Returns:
      status: MATCH / AMBIGUOUS / NO_MATCH / ERROR
      candidates: list of candidate dicts
    """
    q = person_name.strip()
    url = SEARCH_URL + "?q=" + quote_plus(q)

    try:
        r = session.get(url, headers=HEADERS, timeout=TIMEOUT)
        r.raise_for_status()
    except Exception:
        return "ERROR", []

    candidates = extract_candidates_from_html(r.text)

    if not candidates:
        return "NO_MATCH", []

    # enrich candidates with profile-derived name
    enriched = []
    target = norm_name(person_name)
    exact = []

    for cand in candidates[:10]:
        time.sleep(SLEEP_SECONDS)
        try:
            profile_name = fetch_profile_name(session, cand["profile_url"])
        except Exception:
            profile_name = ""

        row = {
            **cand,
            "profile_name": profile_name,
        }
        enriched.append(row)

        if norm_name(profile_name) == target or norm_name(cand["link_text"]) == target:
            exact.append(row)

    if len(exact) == 1:
        return "MATCH", exact
    if len(exact) > 1:
        return "AMBIGUOUS", exact

    # fallback: one candidate only
    if len(enriched) == 1:
        return "MATCH", enriched

    return "AMBIGUOUS", enriched


def main() -> None:
    if not PT_PATH.exists():
        print(f"Missing {PT_PATH}", file=sys.stderr)
        sys.exit(1)

    pt = []
    with PT_PATH.open("r", encoding="utf-8", newline="") as f:
        for row in csv.DictReader(f):
            pt.append(row)

    cache = load_cache(CACHE_PATH)
    cache_rows = list(cache.values())

    ambiguous_rows: list[dict] = []
    miss_rows: list[dict] = []

    session = requests.Session()

    for i, row in enumerate(pt, start=1):
        person = (row.get("person_canon") or "").strip()
        existing_id = (row.get("legacy_member_id") or "").strip()

        if not person:
            continue
        if existing_id:
            continue
        if person in cache:
            continue

        print(f"[{i}/{len(pt)}] {person}")
        status, candidates = search_member(session, person)

        if status == "MATCH" and candidates:
            best = candidates[0]
            cache_rows.append(
                {
                    "person_canon": person,
                    "member_id": best["member_id"],
                    "profile_name": best.get("profile_name", ""),
                    "profile_url": best.get("profile_url", ""),
                    "match_status": status,
                }
            )
        elif status == "AMBIGUOUS":
            for cand in candidates:
                ambiguous_rows.append(
                    {
                        "person_canon": person,
                        "member_id": cand.get("member_id", ""),
                        "profile_name": cand.get("profile_name", ""),
                        "profile_url": cand.get("profile_url", ""),
                        "link_text": cand.get("link_text", ""),
                        "match_status": status,
                    }
                )
        else:
            miss_rows.append(
                {
                    "person_canon": person,
                    "match_status": status,
                }
            )

        time.sleep(SLEEP_SECONDS)

    save_rows(
        CACHE_PATH,
        cache_rows,
        ["person_canon", "member_id", "profile_name", "profile_url", "match_status"],
    )
    save_rows(
        AMBIG_PATH,
        ambiguous_rows,
        ["person_canon", "member_id", "profile_name", "profile_url", "link_text", "match_status"],
    )
    save_rows(
        MISS_PATH,
        miss_rows,
        ["person_canon", "match_status"],
    )

    print(f"\nWrote {CACHE_PATH}")
    print(f"Wrote {AMBIG_PATH}")
    print(f"Wrote {MISS_PATH}")


if __name__ == "__main__":
    main()
