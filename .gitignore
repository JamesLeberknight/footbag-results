# =========================================================
# Python / Environment
# =========================================================
__pycache__/
*.pyc
*.pyo
*.pyd
*.log
*.tmp

# virtual environments
venv/
.venv/
env/
footbag_venv/

# =========================================================
# OS / Editor
# =========================================================
.DS_Store
Thumbs.db
.vscode/
.idea/

# =========================================================
# Large / Raw Image Data (CRITICAL)
# =========================================================

# raw scans (never commit)
early_data/raw_pages/
early_data/preprocessed_pages/

# intermediate image work
early_data/preprocessed_pages/**

# =========================================================
# Generated PPT / image exports
# =========================================================
*.pptx
*.ppt
*.jpg
*.jpeg
*.png
*.tiff

# (optional) if you want to keep final curated images, comment above and use:
# !early_data/preprocessed_pages/final/*.jpg

# =========================================================
# Temporary / Scratch Outputs
# =========================================================

# Gemini intermediate outputs (optional)
early_data/review/*.json

# QC scratch files
early_data/review/tmp/
early_data/review/debug/

# =========================================================
# Keep FINAL DATA (IMPORTANT)
# =========================================================

# DO NOT IGNORE THESE — they are your deliverables
!early_data/event_blocks/
!early_data/placements/
!early_data/old_results/
!early_data/canonical/
!early_data/identity/

# =========================================================
# Spreadsheets (decide policy)
# =========================================================

# If large / frequently regenerated:
# early_data/out/*.xlsx

# If you want to keep the final deliverable:
!early_data/out/footbag_results_pre1997_recovery.xlsx

# =========================================================
# Archives / dumps
# =========================================================
*.zip
*.tar
*.gz

# =========================================================
# Safety: ignore everything in early_data by default (optional advanced)
# then explicitly allow what you want (commented out for now)
# =========================================================
# early_data/*
# !early_data/event_blocks/
# !early_data/placements/
# !early_data/old_results/
# !early_data/canonical/
# !early_data/identity/
# !early_data/docs/
# !early_data/out/
